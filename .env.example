# SingleLineIQ - Local Environment Variables Example
# Copy this file to '.env' in the root directory and configure as needed.

APP_NAME=SingleLineIQ

# Gemini Vision & Language API Toggles
# To enable live Vertex AI / Google GenAI extraction, set USE_GEMINI=true and configure your API key.
USE_GEMINI=false
GOOGLE_API_KEY=

# Fallback Demo Controls
# Set USE_DEMO_SLD_EXTRACT=true to use pre-compiled visual extracts when Gemini is offline.
USE_DEMO_SLD_EXTRACT=true

# Data Assets Directory
DATA_DIR=../data/synthetic
